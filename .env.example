# Supabase Configuration (used by frontend)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic API Key (server-side only - used by Vercel serverless function)
# Do NOT prefix with VITE_ to keep it server-side only
ANTHROPIC_API_KEY=your_anthropic_api_key

# Plaid Configuration (server-side only)
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
